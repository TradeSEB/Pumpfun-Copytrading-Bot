# Solana RPC
RPC_HTTP_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Private key: JSON array (recommended) or base58 string
PRIVATE_KEY=[12,34,56]

# Comma-separated wallet addresses to watch
TARGET_WALLETS=wallet1,wallet2

# Trading mode: true => TP/SL auto sell, false => mirror target sell
AUTO_SELL=true

# Buy sizing
BUY_RATIO=1.0
MIN_BUY_SOL=0.01
MAX_BUY_SOL=0.2

# Risk / execution
TAKE_PROFIT_PCT=25
STOP_LOSS_PCT=12
SLIPPAGE_BPS=500
PRIORITY_FEE_LAMPORTS=50000

# Poll interval for TP/SL checks
PRICE_CHECK_INTERVAL_MS=7000